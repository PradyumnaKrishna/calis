generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Questionnaire {
  id          String   @id
  version     Int
  slug        String   @unique
  title       String
  description String
  isActive    Boolean  @default(false) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  steps QuestionnaireStep[]

  @@map("questionnaires")
}

model QuestionnaireStep {
  questionnaireId String @map("questionnaire_id")
  stepId          String @map("step_id")
  position        Int
  type            String
  eyebrow         String
  question        String
  hint            String
  minSelections   Int?   @map("min_selections")
  maxSelections   Int?   @map("max_selections")

  questionnaire Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  options       QuestionnaireOption[]

  @@id([questionnaireId, stepId])
  @@unique([questionnaireId, position])
  @@map("questionnaire_steps")
}

model QuestionnaireOption {
  questionnaireId String @map("questionnaire_id")
  stepId          String @map("step_id")
  optionId        String @map("option_id")
  position        Int
  label           String
  score           Int?

  step QuestionnaireStep @relation(fields: [questionnaireId, stepId], references: [questionnaireId, stepId], onDelete: Cascade)

  @@id([questionnaireId, stepId, optionId])
  @@unique([questionnaireId, stepId, position])
  @@map("questionnaire_options")
}
