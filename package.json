{
  "name": "calis",
  "version": "0.0.0",
  "module": "index.ts",
  "scripts": {
    "dev:api": "cd apps/api && python3 -m venv .venv && .venv/bin/pip install -e . && .venv/bin/calis-api-seed && .venv/bin/uvicorn src.main:app --reload --host 0.0.0.0 --port 3001",
    "dev:mobile": "bun --cwd apps/mobile start",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx}\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/mobile",
    "packages/*"
  ]
}
