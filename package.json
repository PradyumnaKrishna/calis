{
  "name": "calis",
  "version": "0.0.0",
  "module": "index.ts",
  "scripts": {
    "dev:api": "bun --cwd apps/api dev",
    "dev:mobile": "bun --cwd apps/mobile start",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx}\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
